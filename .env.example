# Server — safe to commit (placeholders only).
# Locally: copy to `.env.local.example` or `.env`, fill in secrets; never commit those files.
PORT=3000
FRONTEND_URL=http://localhost:5173

# Stub user for PoC; future: real session user id
DEFAULT_USER_ID=default

# Google Cloud OAuth (YouTube Data API v3)
# Redirect URI must match Google Console: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# TikTok Login Kit + Content Posting (video.publish, user.info.basic)
# Redirect URI must match TikTok app: http://localhost:3000/api/auth/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback
